APP_ENVIRONMENT=dev

# =====================================================================
# Database Settings
# =====================================================================
# Connection details for the PostgreSQL database equipped with pgvector.
# Points to either a local container or a GCP Cloud SQL instance.
DB_HOST=db.jpgcp.cloud
DB_PORT=5432
DB_NAME=rag_evaluation_db
DB_USER=nvd11
DB_PASSWORD=hsbc1234

# =====================================================================
# Google AI API Settings
# =====================================================================
# Using Google AI Studio API Key (for ease of evaluation testing)
# instead of complex GCP Vertex AI Service Accounts.
GEMINI_API_KEY=your_gemini_api_key_here

# =====================================================================
# RAG Hyperparameters: Data Ingestion (Chunking & Embedding)
# =====================================================================
# The text embedding model to use for vector generation.
EMBEDDING_MODEL=models/gemini-embedding-001
# The dimensionality of the vector space (must match pgvector schema).
EMBEDDING_DIMENSION=768
# Number of chunks to process in a single API call to avoid rate limits.
EMBEDDING_BATCH_SIZE=100

# Text chunking strategy parameters.
# CHUNK_SIZE: Maximum number of characters (not tokens) per extracted chunk.
CHUNK_SIZE=1000
# CHUNK_OVERLAP: Number of overlapping characters between adjacent chunks 
# to preserve semantic continuity across split boundaries.
CHUNK_OVERLAP=200

# =====================================================================
# RAG Hyperparameters: Retrieval & Evaluation
# =====================================================================
# The maximum number of relevant document chunks to retrieve per query.
RETRIEVAL_TOP_K=5
# The minimum Cosine Similarity score [-1, 1] required for a chunk to be 
# considered relevant. Chunks below this threshold are discarded to reduce hallucination.
RETRIEVAL_SIMILARITY_THRESHOLD=0.5

# The primary Generative AI model used to synthesize answers AND 
# act as the "LLM-as-a-Judge" for the RAG Triad evaluation.
LLM_JUDGE_MODEL=gemini-2.5-pro

# =====================================================================
# Network / Proxy Settings
# =====================================================================
# Global proxy settings for developers accessing APIs from restricted regions.
# Set ENABLE_PROXY=true in your local .env to route Google API traffic.
ENABLE_PROXY=false
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890